# ─── Auth Keys ─────────────────────────────────────────────────────────
# Required: one provider key (MERCURY_ prefix stripped when passed to container)
MERCURY_ANTHROPIC_API_KEY=
# MERCURY_OPENAI_API_KEY=

# ─── Identity ──────────────────────────────────────────────────────────
MERCURY_CHATSDK_USERNAME=mercury
MERCURY_CHATSDK_PORT=3000
MERCURY_TRIGGER_PATTERNS=@Mercury,Mercury

# ─── Model ─────────────────────────────────────────────────────────────
MERCURY_MODEL_PROVIDER=anthropic
MERCURY_MODEL=claude-sonnet-4-20250514

# ─── Runtime ───────────────────────────────────────────────────────────
MERCURY_DATA_DIR=.mercury
MERCURY_MAX_CONCURRENCY=2
MERCURY_LOG_LEVEL=info

# ─── Containerized Agent Runtime ───────────────────────────────────────
MERCURY_AGENT_CONTAINER_IMAGE=mercury-agent:latest

# Optional: admin caller IDs (comma-separated)
# MERCURY_ADMINS=

# ─── Container Passthrough ─────────────────────────────────────────────
# All MERCURY_* vars are passed to containers with prefix stripped.
# Example: MERCURY_MY_API_KEY=xxx becomes MY_API_KEY=xxx in container

# ─── WhatsApp Ingress ──────────────────────────────────────────────────
MERCURY_ENABLE_WHATSAPP=false

# ─── Slack Ingress ─────────────────────────────────────────────────────
# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=

# ─── Discord Ingress ───────────────────────────────────────────────────
# DISCORD_BOT_TOKEN=
# DISCORD_PUBLIC_KEY=
# DISCORD_APPLICATION_ID=
