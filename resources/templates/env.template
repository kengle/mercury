# ─── Identity ──────────────────────────────────────────────────────────
MERCURY_BOT_USERNAME=mercury
MERCURY_PORT=3000
MERCURY_TRIGGER_PATTERNS=@Mercury,Mercury

# ─── Image ─────────────────────────────────────────────────────────────
# Docker image name and tag. Change this to rebuild with a new tag.
MERCURY_IMAGE=mercury-agent:latest

# ─── Model ─────────────────────────────────────────────────────────────
MERCURY_ALI_API_KEY=sk-xxx
MERCURY_MODEL_PROVIDER=ali
MERCURY_MODEL=qwen3.5-plus

# ─── Runtime ───────────────────────────────────────────────────────────
MERCURY_LOG_LEVEL=debug

# ─── WhatsApp Ingress ──────────────────────────────────────────────────
MERCURY_ENABLE_WHATSAPP=false

# ─── Discord Ingress ───────────────────────────────────────────────────
MERCURY_ENABLE_DISCORD=false
# MERCURY_DISCORD_BOT_TOKEN=

# ─── Slack Ingress ─────────────────────────────────────────────────────
MERCURY_ENABLE_SLACK=false
# MERCURY_SLACK_BOT_TOKEN=
# MERCURY_SLACK_SIGNING_SECRET=


# ─── WeCom (Enterprise WeChat) Ingress ─────────────────────────────────
MERCURY_ENABLE_WECOM=false
# MERCURY_WECOM_BOT_ID=
# MERCURY_WECOM_SECRET=

# ─── Telemetry ─────────────────────────────────────────────────────────
# MERCURY_OTEL_ENDPOINT=http://localhost:4318
# MERCURY_OTEL_SERVICE=mercury
